{
  "name": "official_website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const o={recursive:true,force:true,maxRetries:8,retryDelay:150};try{fs.rmSync('.next',o);console.log('Removed .next')}catch(e){console.error(e.message);process.exit(1)}\"",
    "dev": "next dev",
    "build": "next build",
    "build:github": "cross-env GITHUB_PAGES=1 GITHUB_PAGES_REPOSITORY=official_website next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "^14.2.30",
    "next-intl": "^3.26.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
